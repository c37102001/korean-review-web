rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/records/{recordId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/grammarNotes/{noteId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/progressShards/{shardId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/reviewDays/{date} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/settings/{settingId} {
      allow read, create: if isOwner(uid);
      allow update: if isOwner(uid)
        && request.resource.data.completedReviewDates is list
        && request.resource.data.completedReviewDates.hasAll(resource.data.completedReviewDates);
      allow delete: if false;
    }
  }
}
